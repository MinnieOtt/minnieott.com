rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate path/document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to check if signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to verify Minnie as the authorized Administrator
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email == "minnie.ott@gmail.com" &&
             request.auth.token.email_verified == true;
    }

    // Rules for posts collection
    match /posts/{postId} {
      // Anyone can fetch posts or list posts
      allow read: if true;

      // Only the admin can write, create, edit, or delete posts
      allow create: if isAdmin() && isValidId(postId) && isValidBlogPost(request.resource.data);
      allow update: if isAdmin() && isValidId(postId) && isValidBlogPost(request.resource.data);
      allow delete: if isAdmin() && isValidId(postId);
    }

    // Strict validation blueprint for a BlogPost
    function isValidBlogPost(data) {
      return data.keys().hasAll(['id', 'title', 'slug', 'content']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() >= 5 && data.title.size() <= 200 &&
             data.slug is string && data.slug.size() <= 200 && data.slug.matches('^[a-z0-9_-]+$') &&
             data.content is string && data.content.size() <= 100000;
    }
  }
}
